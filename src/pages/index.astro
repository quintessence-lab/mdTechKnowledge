---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const redirectUrl = `${base}categories/Claude%E6%8A%80%E8%A1%93%E8%A7%A3%E8%AA%AC/`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
    <title>リダイレクト中...</title>
  </head>
  <body>
    <p><a href={redirectUrl}>Claude技術解説</a>へ移動します...</p>
  </body>
</html>
