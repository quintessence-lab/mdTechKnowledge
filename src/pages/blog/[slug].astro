---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection } from 'astro:content';
import noteUrls from '../../data/note-urls.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// note公開済み(handoff note: ON)の記事は canonical を note URL に向ける（note=本体方針）。
// 未公開記事はマップに無いため undefined となり、canonical は出力されない（自URLが正規）。
const canonical = (noteUrls as Record<string, string>)[post.slug];
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  tags={post.data.tags}
  rawContent={post.body}
  canonical={canonical}
>
  <Content />
</PostLayout>
