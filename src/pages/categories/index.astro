---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog')).filter((p) => !p.data.draft);

const catCount = new Map<string, number>();
for (const post of posts) {
  catCount.set(post.data.category, (catCount.get(post.data.category) || 0) + 1);
}
const categories = [...catCount.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="カテゴリ一覧">
  <h1 class="page-title">カテゴリ一覧</h1>
  <div class="category-grid">
    {categories.map(([cat, count]) => (
      <a href={`${base}categories/${cat}/`} class="category-card">
        <h2 class="category-name">{cat}</h2>
        <p class="category-count">{count} 件の記事</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 1.5rem;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .category-card {
    display: block;
    padding: 1.5rem;
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, background-color 0.2s;
  }

  .category-card:hover {
    box-shadow: var(--shadow-md);
    background-color: var(--color-card-hover);
    text-decoration: none;
  }

  .category-name {
    font-size: 1.15rem;
    margin: 0 0 0.25rem 0;
    color: var(--color-text);
  }

  .category-count {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
