---
interface Props {
  title: string;
  slug: string;
  category: string;
  tags: string[];
  date: Date;
  excerpt?: string;
}

const { title, slug, category, tags, date, excerpt } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const dateStr = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<a href={`${base}blog/${slug}/`} class="post-card">
  <div class="post-card-meta">
    <span class="post-card-date">{dateStr}</span>
    <span class="post-card-category">{category}</span>
  </div>
  <h2 class="post-card-title">{title}</h2>
  {excerpt && <p class="post-card-excerpt">{excerpt}</p>}
  <div class="post-card-tags">
    {tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</a>

<style>
  .post-card {
    display: block;
    background-color: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: box-shadow 0.2s, background-color 0.2s;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .post-card:hover {
    box-shadow: var(--shadow-md);
    background-color: var(--color-card-hover);
    text-decoration: none;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .post-card-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .post-card-category {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-card-category:hover {
    text-decoration: underline;
  }

  .post-card-title {
    font-size: 1.15rem;
    margin: 0 0 0.5rem 0;
    color: var(--color-text);
  }

  .post-card-excerpt {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .post-card-tags {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    font-size: 0.8rem;
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    border-radius: 4px;
  }
</style>
